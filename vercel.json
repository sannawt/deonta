{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "python3 -m pip install -r requirements.txt && test -d frontend || (echo 'ERROR: No frontend/ — connect repo sannawt/compliance_calculator branch main' && exit 1) && cd frontend && npm ci",
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/legacy", "destination": "/api" }
  ],
  "functions": {
    "api/index.py": {
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "{build/**,data/legal_graph/**,rules/**,schemas/**,logic/**}"
    }
  }
}
