obligation(A, X, "AIAct_A50.3_inform_exposed_persons_emotion_recognition") :- applies_via_actor(X, T, "ai_act", A), deployer(A, X), emotion_recognition_system(X).
// AIAct_A50_P3_INFORM_BIOMETRIC_CATEGORISATION
obligation(A, X, "AIAct_A50.3_inform_exposed_persons_biometric_categorisation") :- applies_via_actor(X, T, "ai_act", A), deployer(A, X), biometric_categorisation_system(X).
// AIAct_A50_P4_DISCLOSE_DEEP_FAKE
obligation(A, X, "AIAct_A50.4_disclose_deep_fake_content") :- applies_via_actor(X, T, "ai_act", A), deployer(A, X), deep_fake_generation_or_manipulation(X),!deep_fake_disclosure_exempt(X).
// AIAct_A50_P4_DISCLOSE_AI_GENERATED_PUBLIC_INTEREST_TEXT
obligation(A, X, "AIAct_A50.4_disclose_ai_generated_public_interest_text") :- applies_via_actor(X, T, "ai_act", A), deployer(A, X), generated_text_public_interest(X),!human_review_or_editorial_control(X).
// AIAct_A50_P5_CLEAR_NOTICE_FROM_P1
obligation(A, X, "AIAct_A50.5_clear_distinguishable_accessible_information") :- obligation(A, X, "AIAct_A50.1_inform_natural_person_ai_interaction").
// AIAct_A50_P5_CLEAR_NOTICE_FROM_P3_EMOTION
obligation(A, X, "AIAct_A50.5_clear_distinguishable_accessible_information") :- obligation(A, X, "AIAct_A50.3_inform_exposed_persons_emotion_recognition").
// AIAct_A50_P5_CLEAR_NOTICE_FROM_P3_BIOMETRIC
obligation(A, X, "AIAct_A50.5_clear_distinguishable_accessible_information") :- obligation(A, X, "AIAct_A50.3_inform_exposed_persons_biometric_categorisation").
// AIAct_A50_P5_CLEAR_NOTICE_FROM_P4_DEEP_FAKE
obligation(A, X, "AIAct_A50.5_clear_distinguishable_accessible_information") :- obligation(A, X, "AIAct_A50.4_disclose_deep_fake_content").
// AIAct_A50_P5_CLEAR_NOTICE_FROM_P4_TEXT
obligation(A, X, "AIAct_A50.5_clear_distinguishable_accessible_information") :- obligation(A, X, "AIAct_A50.4_disclose_ai_generated_public_interest_text").
// AIAct_A51_P1_PT_a_HIGH_IMPACT_BY_COMPUTE
gpai_high_impact_capability(X) :- gpai_model(X), has_feature(X, "compute_above_10e25").
// AIAct_A51_P1_PT_a_HIGH_IMPACT_DIRECT
gpai_high_impact_capability(X) :- gpai_model(X), has_feature(X, "high_impact_capabilities").
// AIAct_A52_P1_NOTIFY_COMMISSION
obligation(A, X, "AIAct_A52.1_notify_commission_within_two_weeks") :- applies_via_actor(X, T, "ai_act", A), provider(A, X), gpai_model(X), gpai_high_impact_capability(X).
// AIAct_A52_P1_INCLUDE_DEMONSTRATING_INFORMATION
obligation(A, X, "AIAct_A52.1_include_information_demonstrating_requirement_met") :- applies_via_actor(X, T, "ai_act", A), provider(A, X), gpai_model(X), gpai_high_impact_capability(X).

// ---- generated universal orchestration ----
in_force(R, "current") :- entry_into_force(R, _).
in_force(R, "current") :- application_date(R, "general", _).
applies(S, T, R) :- in_force(R, T), regulation_territorial_link(R, A, S), regulation_material(R, S), !regulation_excluded(R, S).
applies_via_actor(S, T, R, A) :- in_force(R, T), regulation_territorial_link(R, A, S), regulation_material(R, S), !regulation_excluded(R, S).
regulation_material("ai_act", S) :- ai_act_material(S).
regulation_territorial_link("ai_act", A, S) :- ai_act_territorial_link(A, S).
regulation_excluded("ai_act", S) :- ai_act_excluded(S).
regulation_material("gdpr", S) :- gdpr_material(S).
regulation_territorial_link("gdpr", A, S) :- gdpr_territorial_link(A, S).
regulation_excluded("gdpr", S) :- gdpr_excluded(S).
