// GDPR_A3_P2_PT_a_specific
gdpr_art3_2_applies(A, S) :- controller(A, S), data_subjects_in_eu_targeted(S, A).
// GDPR_A3_P2_PT_a_specific_processor
gdpr_art3_2_applies(A, S) :- processor(A, S), data_subjects_in_eu_targeted(S, A).
// GDPR_A3_P2_PT_b_specific
gdpr_art3_2_applies(A, S) :- controller(A, S), monitors_behaviour_in_eu(A, S).
// GDPR_A3_P2_PT_b_specific_processor
gdpr_art3_2_applies(A, S) :- processor(A, S), monitors_behaviour_in_eu(A, S).
// GDPR_A9_2_a_exception
gdpr_art9_exception(S) :- explicit_consent_special_category(S).
// GDPR_A9_2_b_exception
gdpr_art9_exception(S) :- employment_social_security_law_basis(S).
// GDPR_A9_2_c_exception
gdpr_art9_exception(S) :- vital_interests_incapable(S).
// GDPR_A9_2_d_exception
gdpr_art9_exception(S) :- nonprofit_legitimate_activity_safeguards(S).
// GDPR_A9_2_e_exception
gdpr_art9_exception(S) :- manifestly_public_by_data_subject(S).
// GDPR_A9_2_f_exception
gdpr_art9_exception(S) :- legal_claims_or_judicial_capacity(S).
// GDPR_A9_2_g_exception
gdpr_art9_exception(S) :- substantial_public_interest_law_basis(S).
// GDPR_A9_2_h_exception
gdpr_art9_exception(S) :- healthcare_socialcare_law_or_contract(S).
// GDPR_A9_2_i_exception
gdpr_art9_exception(S) :- public_health_interest_law_basis(S).
// GDPR_A9_2_j_exception
gdpr_art9_exception(S) :- research_archiving_statistics_law_basis(S).
// GDPR_A9_P1_PROHIBITION
prohibition(A, S, "GDPR_A9.1_process_special_category_data") :- applies_via_actor(S, T, "gdpr", A), processing_concerns(S, D), special_category_data(D),!gdpr_art9_exception(S).
// GDPR_A10_PROHIBITION
prohibition(A, S, "GDPR_A10_process_criminal_offence_data_without_authority_or_law") :- applies_via_actor(S, T, "gdpr", A), processing_concerns(S, D), criminal_offence_data(D),!official_authority_control(S),!law_authorises_criminal_data_processing(S).
// GDPR_A11_P1_NO_EXTRA_IDENTIFICATION
no_obligation(A, S, "GDPR_A11.1_maintain_acquire_or_process_additional_identification_info") :- applies_via_actor(S, T, "gdpr", A), controller(A, S), identification_not_required_for_purposes(S).
// GDPR_A11_P2_INFORM_CANNOT_IDENTIFY
obligation(A, S, "GDPR_A11.2_inform_data_subject_cannot_identify_if_possible") :- applies_via_actor(S, T, "gdpr", A), controller(A, S), not_in_position_to_identify_data_subject(S), informing_data_subject_possible(S).
// GDPR_A27_P2_EXEMPT_OCCASIONAL
gdpr_representative_obligation_exempt(A, S) :- gdpr_art3_2_applies(A, S), occasional_processing(S),!large_scale_special_category_processing(S),!large_scale_criminal_offence_processing(S).
// GDPR_A27_P2_EXEMPT_PUBLIC_AUTHORITY
gdpr_representative_obligation_exempt(A, S) :- gdpr_art3_2_applies(A, S), public_authority_body(A).
// GDPR_A27_P1_DESIGNATE_REPRESENTATIVE
obligation(A, S, "GDPR_A27.1_designate_representative_in_union") :- applies_via_actor(S, T, "gdpr", A), gdpr_art3_2_applies(A, S),!gdpr_representative_obligation_exempt(A, S).
