# Copy to .env (non-secret settings). Put Aura passwords in .env.local or
# compliance_secrets.env next to main.py (gitignored) if .env does not persist them.
#
# Neo4j Aura (URI host *.databases.neo4j.io): Bolt user and database name are the
# instance id (the subdomain before .databases.neo4j.io), same as the Query API docs.
# This app maps USER/DATABASE from "neo4j" to that id automatically for Aura URIs.

NEO4J_LEGAL_URI=neo4j+s://35cd1f64.databases.neo4j.io
NEO4J_LEGAL_USER=neo4j
NEO4J_LEGAL_PASSWORD=
NEO4J_LEGAL_DATABASE=neo4j

NEO4J_PLAYBOOK_URI=neo4j+s://8f766652.databases.neo4j.io
NEO4J_PLAYBOOK_USER=neo4j
NEO4J_PLAYBOOK_PASSWORD=
NEO4J_PLAYBOOK_DATABASE=neo4j

# If your editor shows passwords in .env but `python -c "..."` still prints chars: 0,
# the file on disk is still empty: save the tab, or create `.env.local` next to main.py:
#
#   NEO4J_LEGAL_PASSWORD=paste-here
#   NEO4J_PLAYBOOK_PASSWORD=paste-here
#
# Or:  printf '%s\n' 'NEO4J_LEGAL_PASSWORD=...' 'NEO4J_PLAYBOOK_PASSWORD=...' > .env.local
